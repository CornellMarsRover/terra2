<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="rock2">
    <static>true</static> <!-- Set to true if the model should not move -->
    <pose>0 0 0 0 0 0</pose>

    <!--z offset is 0.3 for full scale-->

    <link name="link">
      <collision name="rock2_collision">
        <geometry>
          <mesh>
            <uri>model://meshes/rock2.dae</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name="rock2_visual">
        <geometry>
          <mesh>
            <uri>model://meshes/rock2.dae</uri>
          </mesh>
        </geometry>
        <material>
          <script>
            <uri>model://materials/scripts/sand_pebbles.material</uri>
            <name>custom_ground/Image</name>
          </script>
        </material>
      </visual>
    </link>
  </model>
</sdf>

