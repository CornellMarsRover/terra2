<?xml version="1.0" encoding="UTF-8"?>
<robot name="Arm">
  <!-- Group for the main arm -->
  <group name="main_arm">
    <chain base_link="base_link" tip_link="wrist_twist_rotate" />
  </group>
  
  <!-- Group for the end effector -->
  <group name="end_effector">
    <link name="end_effector"/>
  </group>

  <!-- Define a virtual joint for your robot base -->
  <virtual_joint name="fixed_base" type="fixed" parent_frame="world" child_link="base_link" />
  
  <!-- Disable collision between adjacent links -->
  <disable_collisions link1="base_link" link2="shoulder" reason="Adjacent" />
  <disable_collisions link1="shoulder" link2="lower_arm" reason="Adjacent" />
  <disable_collisions link1="lower_arm" link2="upper_arm" reason="Adjacent" />
  <disable_collisions link1="upper_arm" link2="wrist_rotate" reason="Adjacent" />
  <disable_collisions link1="wrist_rotate" link2="wrist_twist_rotate" reason="Adjacent" />
  <disable_collisions link1="wrist_twist_rotate" link2="end_effector" reason="Adjacent" />
  
  <!-- Define more disable collision tags if there are non-adjacent links that should not check for collisions -->
  <!-- Example: <disable_collisions link1="link_name_1" link2="link_name_2" reason="Never"/> -->
  
  <!-- Example group states -->
  <group_state name="home_position" group="main_arm">
    <joint name="base_joint" value="0" />
    <joint name="shoulder_joint" value="0" />
    <joint name="elbow_joint" value="0" />
    <joint name="wrist_rotate" value="0" />
    <joint name="wrist_twist" value="0" />
    <joint name="wrist_rotate_two" value="0" />
  </group_state>
  
  <!-- End effector details -->
  <end_effector name="gripper" parent_group="end_effector" parent_link="wrist_twist_rotate" />
  
</robot>
