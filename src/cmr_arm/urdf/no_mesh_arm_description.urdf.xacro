<?xml version="1.0"?>
<!--
Author: Daniel Hirsch
This xacro expands into the URDF for the arm.

Note we use a dummy inertia as we never actually care about the intertia
enough to calculate it.

Note that most links have origin's equal to half their lengths

Generate model by running: rosrun xacro xacro -o arm_description.urdf arm_description.urdf.xacro
inside a shell in cmr_arm/arm_description/urdf
 -->

<robot name="arm_description" xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:include filename="arm_macros.urdf.xacro"/>
  <xacro:linkage name="base" origin_xyz="0 0 0" origin_rpy="0 0 0" length="0" radius=".0001" color="0 1 0 1" mass="1000"/>
  <xacro:linkage name="base_rotate" origin_xyz="0 0 0" origin_rpy="0 0 0" length="0.05" radius="0.2" color="1 0 0 1" mass="1" mesh="null" vOrigin_xyz="null" vOrigin_rpy="null"/>
  <xacro:joint_rev name="base_rotate" origin_xyz="0 0 0" parent="base" child="base_rotate" axis="0 0 1" lower_limit="-1.57" upper_limit="1.57"/>
  <xacro:linkage name="shoulder" origin_xyz="0 0 0.17215" origin_rpy="0 0 0" length="0.3443" radius="0.04" color="1 0 0 1" mass=".65" mesh="null" vOrigin_xyz="null" vOrigin_rpy="null"/>
  <xacro:joint_rev name="shoulder" origin_xyz="0 0 0.098" parent="base_rotate" child="shoulder" axis="1 0 0" lower_limit="-1.57" upper_limit="1.57"/>
  <xacro:linkage name="elbow" origin_xyz="0.049 0 0" origin_rpy="0 1.57075 0" length="0.098" radius="0.02" color="0 0 1 1" mass=".10" mesh="null" vOrigin_xyz="null" vOrigin_rpy="null"/>
  <xacro:joint_rev name="elbow" origin_xyz="0 0 0.3443" parent="shoulder" child="elbow" axis="1 0 0" lower_limit="-2.35" upper_limit="2.35"/>
  <xacro:linkage name="second_rotate" origin_xyz="0 0 0.2298" origin_rpy="0 0 0" length="0.4596" radius="0.02" color="0 0.5 0.5 1" mass=".65" mesh="null" vOrigin_xyz="null" vOrigin_rpy="null"/>
  <xacro:joint_rev name="second_rotate" origin_xyz="0.098 0 0" parent="elbow" child="second_rotate" axis="0 0 1" lower_limit="-3.14" upper_limit="3.14"/>
  <xacro:linkage name="third_tilt" origin_xyz="0 0 0.0674" origin_rpy="0 0 0" length="0.1348" radius="0.02" color=".4 .3 .3 1" mass=".30" mesh="null" vOrigin_xyz="null" vOrigin_rpy="null"/>
  <xacro:joint_rev name="third_tilt" origin_xyz="0 0 0.4596" parent="second_rotate" child="third_tilt" axis="1 0 0" lower_limit="-1.57" upper_limit="1.57"/>
  <xacro:linkage name="third_rotate" origin_xyz="0 0 0.0726" origin_rpy="0 0 0" length="0.1452" radius="0.02" color="1 1 1 1" mass=".30" mesh="null" vOrigin_xyz="null" vOrigin_rpy="null"/>
  <xacro:joint_continuous name="third_rotate" origin_xyz="0 0 0.1348" parent="third_tilt" child="third_rotate" axis="0 0 1"/>
  <xacro:linkage name="end_effector" origin_xyz="0 0 0.012" origin_rpy="0 0 0" length="0.025" radius="0.025" color="0 0 0 1" mass=".30"/>
  <!-- The Last Joint is effectively fixed, and exists at the tip of the end effector -->
  <xacro:joint_rev name="end_effector" origin_xyz="0 0 0.1702" origin_rpy="-1 0 0" parent="third_rotate" child="end_effector" axis="0 0 1" lower_limit="0" upper_limit="0" />


</robot>
