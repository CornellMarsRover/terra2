<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="hill1">
    <static>true</static> <!-- Set to true if the model should not move -->
    <pose>0 0 0 0 0 0</pose>

    

    <!--z offset is -15 for full scale-->

    <link name="link">
      <collision name="hill1_collision">
        <geometry>
          
          <mesh>
            <uri>model://meshes/hills.stl</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
      </collision>
      <visual name="hill1_visual">
        <geometry>

          <mesh>
            
            <uri>model://meshes/hills.stl</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
        <material>
          <script>
            <uri>model://materials/scripts/sand_pebbles.material</uri>
            <name>custom_ground/Image</name>
          </script>
        </material>
      </visual>
    </link>
  </model>
</sdf>

