#VRML_SIM R2023a utf8

WorldInfo {
  basicTimeStep 16
}

Viewpoint {
  orientation -0.577 0.577 0.577 2.09
  position 10 10 10
}

TexturedBackground {}
TexturedBackgroundLight {}

# Add a plane with an image texture pointing in +y direction
DEF IMAGE_PLANE Shape {
  appearance Appearance {
    texture ImageTexture {
      url [
        "textures/keyboard.png"
      ]
    }
  }
  geometry Plane {
    size 5 5
  }
  translation 0 5 0
  rotation 1 0 0 -1.5708  # Rotate to face +y
}

# Add a robot node to hold the camera
Robot {
  children [
    DEF CAMERA Device {
      name "camera"
      type "Camera"
      # Set camera resolution
      width 2400
      height 1800
    }
    # Visual representation (e.g., an arrow or box)
    Shape {
      appearance Appearance {
        material Material {
          diffuseColor 1 0 0
        }
      }
      geometry Box {
        size 0.1 0.1 0.1
      }
    }
  ]
  controller "<extern>"
  name "camera"
}
