<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="hill2">
    <static>true</static> <!-- Set to true if the model should not move -->
    <pose>0 0 0 0 0 0</pose>
    
    <!--z offset is -18 for full scale-->

    <link name="link">
      <collision name="hill2_collision">
        
        <geometry>
          
          <mesh>
            <uri>model://meshes/hills.stl</uri>
            <scale>4 4 4</scale>
          </mesh>
        </geometry>
      </collision>
      <visual name="hill2_visual">
        
        <geometry>
          <mesh>
            <uri>model://meshes/hills.stl</uri>
            <scale>4 4 4</scale>
          </mesh>
        </geometry>
        <material>
          <script>
            <uri>model://materials/scripts/sand_pebbles.material</uri>
            <name>custom_ground/Image</name>
          </script>
        </material>
      </visual>
    </link>
  </model>
</sdf>

