<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="drives">

    <xacro:arg name="use_gazebo" default="false" />

    <xacro:arg name="use_fake_hardware" default="true" />
    <xacro:arg name="fake_sensor_commands" default="false" />

    <xacro:include filename="$(find cmr_drives_description)/urdf/drives_description.urdf.xacro" />
    <xacro:include filename="$(find cmr_drives_description)/gazebo/drives.materials.xacro" />
    <xacro:include filename="$(find cmr_drives_description)/ros2_control/drives.ros2_control.xacro" />
    <xacro:include filename="$(find cmr_drives_description)/ros2_control/sensor.ros2_control.xacro" />
    <xacro:include filename="$(find cmr_drives_description)/ros2_control/astro_motor.ros2_control.xacro" />

    <xacro:drives />
    <xacro:drives_ros2_control name="drives"/>
    <xacro:astro_sensor name="test_astro_sensor" prefix="test_"/>
    <xacro:astro_motor_ros2_control name="test_astro_motor" joint="test_astro_joint" />

</robot>
