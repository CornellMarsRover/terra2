<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="custom_ground">
    <static>true</static> <!-- Ground is static and immovable -->
    <link name="ground_link">
      <pose>240 0 0 0 0 0</pose> <!-- Position and orientation relative to the world -->
      <!-- Visual Representation -->
      <visual name="ground_visual">
        <geometry>
          <plane>
            <normal>0 0 1</normal> <!-- Upward facing plane -->
            <size>500 500</size> <!-- Size of the plane -->
          </plane>
        </geometry>
        <material>
          <script>
            <uri>model://materials/scripts/sand_pebbles.material</uri>
            <name>custom_ground/Image</name>
          </script>
        </material>
      </visual>

      <!-- Collision Representation -->
      <collision name="ground_collision">
        <geometry>
          <plane>
            <normal>0 0 1</normal>
            <size>100 100</size>
          </plane>
        </geometry>
      </collision>

    </link>
  </model>
</sdf>
