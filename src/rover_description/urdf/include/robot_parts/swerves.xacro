<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="swerve_z_off" value="-0.2286"/>

  <!-- Macro for Swerve Modules -->
  <xacro:macro name="swerve" params="prefix x y z roll pitch yaw">
    <link name="${prefix}_steering_link">
      <inertial>
        <mass value="1"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.0009375" ixy="0" ixz="0" iyy="0.0009375" iyz="0" izz="0.0009375"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0"/>
        <geometry>
          <box size="0.075 0.075 0.075"/>
        </geometry>
        <material name="blue">
          <color rgba="0.0 0.0 1.0 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0"/>
        <geometry>
          <box size="0.075 0.075 0.075"/>
        </geometry>
      </collision>
    </link>

    <joint name="steering_${prefix}_joint" type="revolute">
      <parent link="${prefix}_leg_link"/>
      <child link="${prefix}_steering_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="${roll} ${pitch} ${yaw}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.1" upper="2.1" effort="20" velocity="6.28"/>
    </joint>
  </xacro:macro>    

  <!-- Instantiate Swerve Modules -->
  <xacro:swerve prefix = "front_right" x="0" y="0" z="${swerve_z_off}" roll="0" pitch="1.22173" yaw="0"/>
  <xacro:swerve prefix = "front_left" x="0" y="0" z="${swerve_z_off}" roll="0" pitch="1.22173" yaw="0"/>
  <xacro:swerve prefix = "rear_right" x="0" y="0" z="${swerve_z_off}" roll="0" pitch="-1.22173" yaw="0"/>
  <xacro:swerve prefix = "rear_left" x="0" y="0" z="${swerve_z_off}" roll="0" pitch="-1.22173" yaw="0"/>

</robot>