<joint name="base_joint" type="continuous">
  <origin xyz="0.0 0.04335 0.0" rpy="0 0 0"/>
  <parent link="base_link"/>
  <child link="shoulder"/>
  <axis xyz="0.0 0.0 1.0"/>
</joint>
<transmission name="base_transmission">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="base_joint"> <!-- This should match the joint name -->
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="base_actuator">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>


<joint name="shoulder_joint" type="continuous">
  <origin xyz="0 -0.044 .361" rpy="0 0 0"/>
  <parent link="shoulder"/>
  <child link="lower_arm"/>
  <axis xyz="1 0 0"/>
</joint>
<transmission name="shoulder_transmission">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="shoulder_joint_revolute">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="shoulder_actuator">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<joint name="elbow_joint" type="continuous">
  <origin xyz="0 -1.4425 0" rpy="0 0 0"/>
  <parent link="lower_arm"/>
  <child link="upper_arm"/>
  <axis xyz="1 0 0"/>
</joint>
<transmission name="elbow_transmission">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="elbow_joint_revolute">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="elbow_actuator">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<joint name="wrist_rotate" type="continuous">
  <origin xyz=".112 -1.4425 0" rpy="0 0 0"/>
  <parent link="upper_arm"/>
  <child link="wrist_rotate"/>
  <axis xyz="0 1 0"/>
</joint>
<transmission name="wrist_rotate_transmission">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="wrist_rotate_revolute">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="wrist_rotate_actuator">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<joint name="wrist_twist" type="continuous">
  <origin xyz="0.0 -.2 0.00508" rpy="0 0 0"/>
  <parent link="wrist_rotate"/>
  <child link="wrist_twist_rotate"/>
  <axis xyz="0 0 1"/>
</joint>
<transmission name="wrist_twist_transmission">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="wrist_twist_revolute">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="wrist_twist_actuator">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<joint name="wrist_rotate_two" type="continuous">
  <origin xyz="-.385 0 -.42" rpy="0 0 0"/>
  <parent link="wrist_twist_rotate"/>
  <child link="end_effector"/>
  <axis xyz="0 1 0"/>
</joint>
<transmission name="wrist_rotate_two_transmission">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="wrist_rotate_two_actuator">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
  </joint>
  <actuator name="wrist_rotate_two_actuator">
    <hardwareInterface>PositionJointInterface</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

