<?xml version="1.0"?>
<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <Sequence>
            <Action ID="Print" message="Testing Pose"/>
            <RecoveryNode number_of_retries="10">
                <!-- <Action ID="Aruco"/> -->
                <AlwaysFailure/>
                <Sequence>
                    <Action ID="PoseGenerator" has_arrived="true" goal="{goal}"/>
                    <!-- <Action ID="Print" message="{testing}"/> -->
                </Sequence>
            </RecoveryNode>
        </Sequence>
    </BehaviorTree>
</root>
