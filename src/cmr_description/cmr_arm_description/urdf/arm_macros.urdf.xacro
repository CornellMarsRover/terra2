<?xml version="1.0"?>
<!--
Author: Aarushi Parashar
This xacro expands into the URDF for the arm. It is included in both the mesh urdf and no_mesh urdf.
 -->

<robot name="arm_description"
  xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:property name="zero" value="0 0 0" />
  <xacro:property name="mesh_path" value="package://cmr_arm_description/meshes/" />

  <xacro:macro name="linkage" params="name origin_xyz origin_rpy length radius color vOrigin_xyz:=null vOrigin_rpy:=null mesh:=null mass:=1">
    <link name="${name}">
      <intertial>
        <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
        <mass value="${mass}" />
        <inertia ixx="0.00035480405869602" ixy="-0.00065199857117274" ixz="0.000191849153841144" iyy="0.00158383903971818" iyz="9.59056305777939E-05" izz="0.00188232432766353" />
      </intertial>
      <visual>
        <geometry>
          <xacro:if value="${mesh == 'null'}">
            <cylinder length="${length}" radius="${radius}"/>
          </xacro:if>
          <xacro:unless value="${mesh == 'null'}">
            <mesh scale="0.01 0.01 0.01" filename="${mesh_path}${mesh}.stl"/>
          </xacro:unless>
        </geometry>
        <xacro:if value="${vOrigin_xyz != 'null' and vOrigin_rpy != 'null'}">
          <origin xyz="${vOrigin_xyz}" rpy="${vOrigin_rpy}" />
        </xacro:if>
        <xacro:unless value="${vOrigin_xyz != 'null' and vOrigin_rpy != 'null'}">
          <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
        </xacro:unless>
        <material name="${name}">
          <color rgba="${color}"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${length}" radius="${radius}"/>
        </geometry>
        <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="linkage_box" params="name origin_xyz origin_rpy radius color mass:=1">
    <link name="${name}">
      <intertial>
        <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
        <mass value="${mass}" />
        <inertia ixx="0.00035480405869602" ixy="-0.00065199857117274" ixz="0.000191849153841144" iyy="0.00158383903971818" iyz="9.59056305777939E-05" izz="0.00188232432766353" />
      </intertial>
      <visual>
        <geometry>
          <box size="${radius} ${radius} ${radius}"/>
        </geometry>
        <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
        <material name="${name}">
          <color rgba="${color}"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="${radius} ${radius} ${radius}"/>
        </geometry>
        <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="joint_rev" params="name origin_xyz origin_rpy:=${zero} parent child axis lower_limit upper_limit">
    <joint name="${name}" type="revolute">
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
      <parent link="${parent}" />
      <child link="${child}" />
      <axis xyz="${axis}" />
      <limit lower="${lower_limit}" upper="${upper_limit}" effort="0" velocity="0" />
    </joint>
  </xacro:macro>

  <xacro:macro name="joint_continuous" params="name origin_xyz parent child axis">
    <joint name="${name}" type="continuous">
      <origin xyz="${origin_xyz}" />
      <parent link="${parent}" />
      <child link="${child}" />
      <axis xyz="${axis}" />
    </joint>
  </xacro:macro>
</robot>
